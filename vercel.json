{
  "version": 2,
  "builds": [
    {
      "src": "backend/career_agent/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 60 }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/nextjs"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/career_agent/wsgi.py"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    }
  ]
}
